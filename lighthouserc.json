{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "settings": {
        "staticDistDir": ".next",
        "urls": [
          "http://localhost:3000/et",
          "http://localhost:3000/et/tooted?tegevusala=kute",
          "http://localhost:3000/et/toode/magna3-25-100-180"
        ],
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "chromeFlags": "--no-sandbox --disable-gpu --disable-dev-shm-usage"
      }
