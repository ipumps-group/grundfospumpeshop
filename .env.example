# ============================================================================
# Environment Variables — Copy this file to .env.local and fill in real values
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────
# SITE CONFIG
# ──────────────────────────────────────────────────────────────────────────

# Production domain (used in robots.txt, sitemap, canonical tags, email links)
NEXT_PUBLIC_SITE_URL=https://pumbapood.ee

# Site name for branding
NEXT_PUBLIC_SITE_NAME=iPumps

# ──────────────────────────────────────────────────────────────────────────
# TRACKING / ANALYTICS — Client-side (NEXT_PUBLIC_* safe for browser)
# ──────────────────────────────────────────────────────────────────────────

# Google Ads conversion ID (gtag)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18154845685

# GA4 Measurement ID (Google Analytics 4 data stream)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-KD26VEJVWY

# Google Tag Manager container ID
NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-MN86P7WH

# Google Ads conversion labels (from Google Ads → Conversions → Conversion actions)
NEXT_PUBLIC_GOOGLE_ADS_ATC_LABEL=bu4ZCOy5gbscEPXr89BD
NEXT_PUBLIC_GOOGLE_ADS_CHECKOUT_LABEL=2AHFCOm5gbscEPXr89BD
NEXT_PUBLIC_GOOGLE_ADS_CONTACT_LABEL=aobnCOa5gbscEPXr89BD
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=JPeXCOO5gbscEPXr89BD

# Optional: Additional conversion labels for enhanced Smart Bidding
# Create these in Google Ads → Conversions if you want:
# - View item tracking (product page views)
# - Site search tracking
# - Generic lead tracking (beyond contact form)
NEXT_PUBLIC_GOOGLE_ADS_VIEW_ITEM_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_SEARCH_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=

# Meta / Facebook Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=2133761077401963

# Meta Conversions API (server-side; never expose this token to the browser)
META_PIXEL_ID=2133761077401963
META_CAPI_ACCESS_TOKEN=
# Optional: use only while verifying events in Meta Events Manager
META_TEST_EVENT_CODE=

# ──────────────────────────────────────────────────────────────────────────
# SUPABASE (Database + Storage)
# ──────────────────────────────────────────────────────────────────────────

# Supabase project URL — from Supabase Settings → API
# Example: https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Supabase anonymous key (public) — from Supabase Settings → API
# Used for client-side reads with Row Level Security (RLS)
# Safe to expose in frontend code
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (secret) — from Supabase Settings → API
# Used server-side to bypass RLS (e.g., in API routes, migrations, sitemap generation)
# NEVER expose to frontend; keep this secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────────────────────────────────
# ANTHROPIC (Claude API for AI Search)
# ──────────────────────────────────────────────────────────────────────────

# Anthropic API key — get from https://console.anthropic.com/
# Used by /api/search-ai for AI-powered product search
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────────────────
# OPENAI (AI Recommendations & Reports)
# ──────────────────────────────────────────────────────────────────────────

# OpenAI API key — get from https://platform.openai.com/api-keys
# Used by Ads Control Panel AI features:
#   - Performance analysis & recommendations
#   - Report summaries & action plans
#   - Change request risk assessment
#   - Budget pacing analysis
#   - Search term analysis
#   - Account audits
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────────────
# MONTONIO (Payment Gateway)
# ──────────────────────────────────────────────────────────────────────────

# Montonio sandbox access key — for testing payments
MONTONIO_ACCESS_KEY=sandbox_access_key_...

# Montonio sandbox secret key — for testing payments
MONTONIO_SECRET_KEY=sandbox_secret_key_...

# Montonio live access key — for production payments
MONTONIO_LIVE_ACCESS_KEY=prod_access_key_...

# Montonio live secret key — for production payments
MONTONIO_LIVE_SECRET_KEY=prod_secret_key_...

# Use sandbox mode (true) or live mode (false)
# Set to false in production
MONTONIO_SANDBOX=true

# ──────────────────────────────────────────────────────────────────────────
# RESEND (Email Service)
# ──────────────────────────────────────────────────────────────────────────

# Resend API key — get from https://resend.com/
# Used for sending transactional emails (order confirmations, password resets, etc.)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@pumbapood.ee
RESEND_REPLY_TO=info@pumbapood.ee
RESEND_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────────────────────────────────
# VERCEL (CI/CD)
# ──────────────────────────────────────────────────────────────────────────

# Vercel deploy hook URL — from Vercel Project → Settings → Git Connections
# Triggers a deploy when Supabase data changes (optional, for automations)
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# ──────────────────────────────────────────────────────────────────────────
# GOOGLE ADS API v24 — Server-side (NEVER expose to frontend)
# ──────────────────────────────────────────────────────────────────────────
# Docs: https://developers.google.com/google-ads/api/docs/get-started

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=           # Main ad account ID (no dashes)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=     # Only if accessing through an MCC

# ──────────────────────────────────────────────────────────────────────────
# GA4 DATA API — Server-side (uses same OAuth as Google Ads)
# ──────────────────────────────────────────────────────────────────────────
# Docs: https://developers.google.com/analytics/devguides/reporting/data/v1

GA4_PROPERTY_ID=                  # GA4 property ID (numeric, from GA4 Admin)

# ──────────────────────────────────────────────────────────────────────────
# META MARKETING API v25.0 — Server-side
# ──────────────────────────────────────────────────────────────────────────
# Docs: https://developers.facebook.com/docs/marketing-api

META_GRAPH_API_VERSION=v25.0
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=               # Include act_ prefix
META_BUSINESS_ID=
META_PAGE_ID=
META_PIXEL_ID=
